#==============================================================
# 文件：docker/.env.example
# 作用：Docker Compose 与运维脚本的环境变量模板
# 使用：cp .env.example .env  然后填入真实值（.env 已被 .gitignore 忽略）
#==============================================================

# ---- MySQL ----
# 生产请改为强密码(>=12位,含大小写数字符号)
MYSQL_ROOT_PASSWORD=ChangeMe_StrongPwd_2024
MYSQL_DB=appdb

# ---- 运维脚本通用 ----
# 告警邮件收件人（未配置 mailx 时仅写日志）
ALERT_MAIL_TO=

# MySQL 备份凭据：优先用 ~/.my.cnf，否则用此变量
# MYSQL_ROOT_PASSWORD=（同上，复用）

# MySQL 备份保留天数
MYSQL_BACKUP_KEEP_DAYS=7

# 日志清理保留天数
LOG_KEEP_DAYS=7

# ---- 阿里云 OSS ----
# aliyun CLI 凭据请用 `aliyun configure` 配置，或设置：
# ALIBABACLOUD_ACCESS_KEY_ID=
# ALIBABACLOUD_ACCESS_KEY_SECRET=
OSS_BUCKET=demo-bucket-lixianqing
OSS_LOCAL_DIR=
